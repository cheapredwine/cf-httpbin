{
  "name": "cf-httpbin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --format=esm --outfile=dist/bundle.js --platform=neutral --conditions=workerd,worker --external:cloudflare:*",
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "npm run bundle && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.1",
    "esbuild": "^0.27.7",
    "miniflare": "^4.20260401.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^3"
  }
}
